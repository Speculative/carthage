# .carthage/docker-compose.yaml — generated by /carthage-annex.
#
# The carthage CLI invokes compose with `-f .carthage/docker-compose.yaml`
# and `-p carthage-{{ project_slug }}`, so just run `carthage up` from the
# project root.
#
# IMPORTANT: By default, NO host-side port bindings. Services are reachable
# between each other via Docker DNS (`redis:6379`, `postgres:5432`, ...)
# but nothing is published to the host. Only services the user explicitly
# opted into during /carthage-annex get a `ports:` block.

name: carthage-{{ project_slug }}

x-carthage-labels: &carthage_labels
  carthage.managed: "true"
  carthage.project: "{{ project_slug }}"

services:
  {{ service_name | default('dev') }}:
    build:
      context: ..
      dockerfile: .carthage/Dockerfile
      args:
        HOST_UID: ${HOST_UID:-1000}
        HOST_GID: ${HOST_GID:-1000}
    image: carthage-{{ project_slug }}:latest
    working_dir: /workspace
    init: true
    tty: true
    stdin_open: true

    labels:
      <<: *carthage_labels
      carthage.role: "dev"
      # Stamp of the base-image version this container was launched against,
      # resolved by the CLI at `up` time from the OCI label on the locally-
      # cached base image. `carthage status` reads this back to flag
      # "running container is older than the base image now on disk."
      # Empty when the base image pre-dates v1.1.0 (no OCI label set).
      carthage.base-image-version: "${CARTHAGE_BASE_IMAGE_VERSION:-}"

    # Hardening — see README "Security model" for the full rationale.
    # NET_ADMIN is intentionally absent: Carthage doesn't try to firewall
    # the container off from the host LAN (defense-in-depth that didn't
    # justify the extra capability for our threat model). SYS_PTRACE is also
    # absent by default; the annex skill prompts and adds it per-project
    # when the user opts in for native debugging (gdb / strace).
    cap_drop: [ALL]
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE{% if wants_ptrace %}
      - SYS_PTRACE      # opted in during annex: native debugging likely needed
{% endif %}
    security_opt:
      - no-new-privileges:true
    pids_limit: 1000
    # CLI resolves these at `up` time (~75% host RAM, host CPUs - 1).
    # Unset vars → 0, which Docker treats as "no limit".
    mem_limit: ${CARTHAGE_MEM_LIMIT:-0}
    cpus: ${CARTHAGE_CPUS:-0}

    environment:
      CARTHAGE: "1"
      CARTHAGE_PROJECT: "{{ project_slug }}"

    volumes:
      - ..:/workspace:rw
      - ${HOME}/.claude:/home/carthage/.claude:rw
      # ~/.claude.json is a sibling of ~/.claude (NOT inside it) and holds the
      # OAuth account + login state. Without this mount, Claude Code starts
      # logged-out inside the container even though .credentials.json is
      # present. Must be rw — the file is rewritten on every session.
      - ${HOME}/.claude.json:/home/carthage/.claude.json:rw
      - ${HOME}/.gitconfig:/home/carthage/.gitconfig:ro
      # Per-project state directory — currently holds .bash_history so shell
      # history persists across `carthage down`/`up`. The CLI ensures this
      # dir exists on the host before invoking `compose up`. Slug-keyed; if
      # two projects share a slug they share state (same caveat as compose
      # project name collisions).
      - ${HOME}/.carthage/state/{{ project_slug }}:/commandhistory:rw
{% if published_ports %}

    # Host-side ports the user opted into during /carthage-annex.
    # Collision detection: `carthage up` will refuse if another Carthage
    # project already owns one of these. Use `carthage up --no-host-ports`
    # or `carthage up --port H:C` to override for one run.
    ports:
{% for port in published_ports %}      - "{{ port }}:{{ port }}"
{% endfor %}
{% endif %}

    networks:
      - carthage-net

{% if services.postgres %}
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: carthage
      POSTGRES_PASSWORD: carthage
      POSTGRES_DB: {{ project_slug }}
    labels:
      <<: *carthage_labels
      carthage.role: "postgres"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - carthage-net
{% endif %}
{% if services.mysql %}
  mysql:
    image: mysql:8.4
    environment:
      MYSQL_ROOT_PASSWORD: carthage
      MYSQL_DATABASE: {{ project_slug }}
    labels:
      <<: *carthage_labels
      carthage.role: "mysql"
    volumes:
      - mysql-data:/var/lib/mysql
    networks:
      - carthage-net
{% endif %}
{% if services.redis %}
  redis:
    image: redis:7-alpine
    command: ["redis-server", "--appendonly", "yes"]
    labels:
      <<: *carthage_labels
      carthage.role: "redis"
    volumes:
      - redis-data:/data
    networks:
      - carthage-net
{% endif %}

networks:
  # Docker assigns a subnet automatically; no fixed range (SPEC_CHANGES §"Drop
  # the in-container LAN firewall entirely" — no reason to pin one).
  carthage-net:
    driver: bridge

{% if services.postgres or services.mysql or services.redis %}
volumes:
{% if services.postgres %}  postgres-data:
{% endif %}{% if services.mysql %}  mysql-data:
{% endif %}{% if services.redis %}  redis-data:
{% endif %}{% endif %}
