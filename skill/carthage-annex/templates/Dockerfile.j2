# .carthage/Dockerfile — generated by /carthage-annex.
#
# Extends carthage-base with project-specific runtimes and tools. The base
# image already includes: git, tmux, curl, openssh-client, jq, ripgrep,
# Python 3.12, uv, Node.js LTS, and the Claude Code CLI.
#
# System packages go here (there is no `sudo` in the running container).
# Do NOT add a trailing `USER carthage` — the base image already sets it,
# and the entrypoint runs as that user.

FROM {{ base_image | default('ghcr.io/speculative/carthage-base:v1') }}

USER root

{% if extra_apt_packages %}
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
{% for pkg in extra_apt_packages %}      {{ pkg }}{% if not loop.last %} \{% endif %}
{% endfor %}
 && rm -rf /var/lib/apt/lists/*

{% endif %}
{% if python_version and python_version != 'system' %}
# Project pins Python {{ python_version }} via `.python-version` or requires-python.
USER carthage
ENV PYENV_ROOT=/home/carthage/.pyenv \
    PATH=/home/carthage/.pyenv/bin:/home/carthage/.pyenv/shims:$PATH
RUN curl -fsSL https://pyenv.run | bash \
 && pyenv install {{ python_version }} \
 && pyenv global {{ python_version }}
USER root

{% endif %}
{% if node_version and node_version != 'system' %}
# Project pins Node {{ node_version }} via `.nvmrc` or package.json `engines`.
USER carthage
ENV NVM_DIR=/home/carthage/.nvm
RUN curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash \
 && . "$NVM_DIR/nvm.sh" \
 && nvm install {{ node_version }} \
 && nvm alias default {{ node_version }}
USER root

{% endif %}
{% if extra_run_lines %}
# Project-specific setup
{% for line in extra_run_lines %}
RUN {{ line }}
{% endfor %}

{% endif %}
USER carthage
WORKDIR /workspace
